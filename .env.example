# Database (PostgreSQL recommended)
DATABASE_URL="postgresql://username:password@localhost:5432/spandha?schema=public"

# NextAuth (URL of your application)
NEXTAUTH_URL="http://localhost:3000"

# JWT Secret (Must be a long random string in production)
# You can generate one with: openssl rand -base64 32
JWT_SECRET="your-secure-jwt-secret-key-change-in-production"

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Third Party Services
OTP_PROVIDER="notify"
NOTIFY_USER_ID="your-notify-user-id"
NOTIFY_API_KEY="your-notify-api-key"
NOTIFY_SENDER_ID="your-notify-sender-id"

EMAIL_PROVIDER="resend"
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# REDIS_URL="" # For Upstash Redis
