# Database (PostgreSQL recommended)
DATABASE_URL="postgresql://username:password@localhost:5432/spandha?schema=public"

# Public site URL (used for SEO, sitemap, emails, PWA)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# JWT Secret (Must be a long random string in production)
# You can generate one with: openssl rand -base64 32
JWT_SECRET="your-secure-jwt-secret-key-change-in-production"

# Google Search Console (optional — omit until you have a verification code)
# GOOGLE_SITE_VERIFICATION="your-google-verification-code"

# Vercel Cron — required in production for /api/cleanup/drafts
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret"

# Supabase Storage (avatars & NIC uploads)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Third Party Services
NOTIFY_USER_ID="your-notify-user-id"
NOTIFY_API_KEY="your-notify-api-key"
NOTIFY_SENDER_ID="your-notify-sender-id"

RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# REDIS_URL="" # For Upstash Redis (OTP store in production)
