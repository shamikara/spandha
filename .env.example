# Database (PostgreSQL recommended)
DATABASE_URL="postgresql://username:password@localhost:5432/spandha?schema=public"

# NextAuth (URL of your application)
NEXTAUTH_URL="http://localhost:3000"

# JWT Secret (Must be a long random string in production)
# You can generate one with: openssl rand -base64 32
JWT_SECRET="your-secure-jwt-secret-key-change-in-production"

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Third Party Services (To be implemented in Phase 4)
# OTP_PROVIDER="twilio"
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# EMAIL_PROVIDER="resend"
# RESEND_API_KEY=""

