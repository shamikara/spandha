generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  phone       String?  @unique
  email       String?  @unique
  isVerified  Boolean  @default(false)
  isAdmin     Boolean  @default(false)
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile     Profile?
  preferences Preferences?
  adverts     Advert[]
  sentInterests     Interest[] @relation("SentInterests")
  receivedInterests Interest[] @relation("ReceivedInterests")

  @@map("users")
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  firstName    String
  lastName     String
  age          Int
  gender       Gender
  location     String
  job          String?
  education    String?
  height       String?
  religion     String?
  caste        String?
  motherTongue String?
  hobbies      String[]
  drinking     String?
  smoking      String?
  description  String?
  avatar       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Performance indexes for filtered queries
  @@index([gender])
  @@index([location])
  @@index([isActive])
  @@index([age])
  @@map("profiles")
}

model Preferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  minAge    Int
  maxAge    Int
  gender    Gender
  location  String?
  religion  String?
  caste     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("preferences")
}

model Advert {
  id        String    @id @default(cuid())
  userId    String
  title     String    @db.VarChar(100)
  content   String    @db.Text
  builderData Json?
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive, expiresAt])
  @@map("adverts")
}

model Interest {
  id         String         @id @default(cuid())
  fromUserId String
  toUserId   String
  status     InterestStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  fromUser User @relation("SentInterests", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedInterests", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("interests")
}

enum Gender {
  MALE
  FEMALE
}

enum InterestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ContentBlock {
  id        String    @id @default(cuid())
  key       String
  locale    Locale    @default(EN)
  type      BlockType
  content   String    // JSON string
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([key, locale])
  @@map("content_blocks")
}

enum BlockType {
  HERO
  BANNER
  ADVERT
  SECTION
}

enum Locale {
  EN
  SI
}
